    {
      "name": "Add Track to Playlist - PUT /playlists/:id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Add Track - Status 200 or 400 or 403\", function () {\r",
              "    pm.expect([200, 400, 403]).to.include(pm.response.code);\r",
              "});\r",
              "\r",
              "let res;\r",
              "try {\r",
              "    res = pm.response.json();\r",
              "} catch (e) {\r",
              "    console.log(\"Add Track: No JSON body:\", e);\r",
              "    return;\r",
              "}\r",
              "\r",
              "if (pm.response.code === 200 && res.tracks) {\r",
              "    pm.test(\"Add Track - Playlist updated\", function () {\r",
              "        pm.expect(res).to.have.property(\"_id\");\r",
              "        pm.expect(res).to.have.property(\"tracks\");\r",
              "        pm.expect(res.tracks).to.be.an(\"array\");\r",
              "    });\r",
              "} else {\r",
              "    console.log(\"Add Track failed:\", res);\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
