  "item": [
    {
      "name": "Register User - POST /users/register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Register - Status 201 or 400 (duplicate)\", function () {\r",
              "    pm.expect([201, 400]).to.include(pm.response.code);\r",
              "});\r",
              "\r",
              "let res;\r",
              "try {\r",
              "    res = pm.response.json();\r",
              "} catch (e) {\r",
              "    console.log(\"No JSON body for register:\", e);\r",
              "    return;\r",
              "}\r",
              "\r",
              "if (pm.response.code === 201 && res._id) {\r",
              "    pm.environment.set(\"user_id\", res._id);\r",
              "\r",
              "    pm.test(\"Register - Response has username & _id\", function () {\r",
              "        pm.expect(res).to.have.property(\"username\");\r",
              "        pm.expect(res).to.have.property(\"_id\");\r",
              "        pm.expect(res).to.not.have.property(\"password\");\r",
              "    });\r",
              "} else {\r",
              "    console.log(\"Register returned non-201:\", res);\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"testuser\",\r\n    \"password\": \"mypassword\"\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users/register",
          "host": ["{{base_url}}"],
          "path": ["users", "register"]
        }
      },
      "response": []
    },
    {
      "name": "Login - POST /users/login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login - Status 200 or 401\", function () {\r",
              "    pm.expect([200, 401]).to.include(pm.response.code);\r",
              "});\r",
              "\r",
              "let res;\r",
              "try {\r",
              "    res = pm.response.json();\r",
              "} catch (e) {\r",
              "    console.log(\"No JSON body for login:\", e);\r",
              "    return;\r",
              "}\r",
              "\r",
              "if (pm.response.code === 200 && res.user && res.access_token) {\r",
              "    pm.environment.set(\"token\", res.access_token);\r",
              "    pm.environment.set(\"user_id\", res.user._id);\r",
              "\r",
              "    pm.test(\"Login - Valid Token Response\", function () {\r",
              "        pm.expect(res).to.have.property(\"token_type\");\r",
              "        pm.expect(res).to.have.property(\"access_token\");\r",
              "        pm.expect(res.user).to.have.property(\"username\");\r",
              "        pm.expect(res.user).to.not.have.property(\"password\");\r",
              "    });\r",
              "} else {\r",
              "    console.log(\"Login failed, not setting token:\", res);\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"testuser\",\r\n    \"password\": \"mypassword\"\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users/login",
          "host": ["{{base_url}}"],
          "path": ["users", "login"]
        }
      },
      "response": []
    },
    {
      "name": "Get User by ID No Playlist - GET /users/:id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Get User - Status 200 or 403\", function () {\r",
              "    pm.expect([200, 403]).to.include(pm.response.code);\r",
              "});\r",
              "\r",
              "if (pm.response.code !== 200) {\r",
              "    console.log(\"User GET failed:\", pm.response.json());\r",
              "    return;\r",
              "}\r",
              "\r",
              "const res = pm.response.json();\r",
              "\r",
              "pm.test(\"Get User - Basic structure correct\", function () {\r",
              "    pm.expect(res).to.have.property(\"_id\");\r",
              "    pm.expect(res).to.have.property(\"username\");\r",
              "    pm.expect(res).to.not.have.property(\"password\");\r",
              "});\r",
              "\r",
              "pm.test(\"Get User - Does NOT include playlists by default\", function () {\r",
              "    pm.expect(res).to.not.have.property(\"playlists\");\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["users", "{{user_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Get User by ID with Playlist - GET /users/:id?playlists=true",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Get User w/ Playlists - Status 200 or 403\", function () {\r",
              "    pm.expect([200, 403]).to.include(pm.response.code);\r",
              "});\r",
              "\r",
              "if (pm.response.code !== 200) {\r",
              "    console.log(\"User GET failed:\", pm.response.json());\r",
              "    return;\r",
              "}\r",
              "\r",
              "const res = pm.response.json();\r",
              "\r",
              "pm.test(\"Get User - Structure correct\", function () {\r",
              "    pm.expect(res).to.have.property(\"_id\");\r",
              "    pm.expect(res).to.have.property(\"username\");\r",
              "});\r",
              "\r",
              "pm.test(\"Get User - Includes playlists array\", function () {\r",
              "    pm.expect(res).to.have.property(\"playlists\");\r",
              "    pm.expect(res.playlists).to.be.an(\"array\");\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}?playlists=true",
          "host": ["{{base_url}}"],
          "path": ["users", "{{user_id}}"],
          "query": [{ "key": "playlists", "value": "true" }]
